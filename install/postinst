#!/bin/sh
# postinst — runs as root after the package's files are unpacked.
# cargo-deb substitutes its systemd fragments (register the unit + daemon-reload;
# enable/start are off, so it won't launch the service) at the token below.
# NOTE: that token must appear EXACTLY ONCE and never inside a comment, or the
# substitution lands in the wrong place and mangles the script.
set -e

# The unit runs the daemon with Group=wirefinder so the socket lands as
# root:wirefinder 0660 — that group is how the unprivileged UI reaches it. The
# group must exist before the service ever starts, so create it here, idempotently.
if ! getent group wirefinder >/dev/null; then
    groupadd --system wirefinder
fi

#DEBHELPER#

# Refresh the icon-theme cache and desktop database so the dock picks up the new
# launcher (Name/Icon/StartupWMClass) immediately — cargo-deb adds no such trigger.
# Runs on both fresh installs and upgrades; guarded + `|| true` to stay idempotent.
if command -v gtk-update-icon-cache >/dev/null 2>&1; then
    gtk-update-icon-cache -q -f /usr/share/icons/hicolor || true
fi
if command -v update-desktop-database >/dev/null 2>&1; then
    update-desktop-database -q /usr/share/applications || true
fi

# First install only ($2 is the old version on upgrade, empty on a fresh install).
if [ "$1" = "configure" ] && [ -z "$2" ]; then
    cat <<'EOF'

wirefinder installed. The daemon is enabled and running — there is no config file
to edit. Just give your login user access to the daemon's socket, then set
everything up in the app:

  1. Let your login user reach the socket:
       sudo usermod -aG wirefinder "$USER"      # then log out and back in
  2. Launch "wirefinder" from your applications menu (or run wirefinder-ui).
     The app walks you through creating your keys and adding your first server.

EOF
fi

exit 0
